# Caddy will listen for connections on the ports that have been mapped to Docker
# For the URL https://nextcloud.local:8443, Caddy will utilize an
# automatically generated and updated, self-signed SSL certificate
{$DOMAIN}:8443 {
    # Forwarding all requests to the internal Nextcloud server
    reverse_proxy app:80

    # reverse_proxy app:80 {
    #     header_up Host {host}
    #     header_up X-Real-IP {remote_host}
    #     header_up X-Forwarded-For {remote_host}
    #     header_up X-Forwarded-Proto {scheme}
    # }

    header {
        X-Frame-Options "SAMEORIGIN"
        Strict-Transport-Security "max-age=63072000"
    }
}

# HTTP port for redirects
{$DOMAIN}:8081 {
    redir https://{$DOMAIN}:8443{uri}
}
