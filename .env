# Domain where Nextcloud will be accessible on the local network
# You can use, for example, nextcloud.local or nextcloud.home
NEXTCLOUD_DOMAIN=nextcloud.local
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.local nextcloud.local:8443

# Database settings
MYSQL_ROOT_PASSWORD=TypeHereHardRootPassword
MYSQL_PASSWORD=TypeHereAnotherHardUserPassword
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud_user
